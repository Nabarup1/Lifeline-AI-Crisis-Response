# LLM Configuration
# Get this from: https://aistudio.google.com/app/apikey (Free)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini

# Which model to use. Change this line to swap models without touching code.
# Free tier options:
#   gemini-3.1-flash-lite    (fastest, highest daily limits, good for JSON tasks)
#   gemma-4-27b-it           (Gemma 4 27B, smarter but slightly lower limits)
GEMINI_MODEL=gemini-3.1-flash-lite

# MCP Server Configuration
MCP_SERVER_PORT=3001
MCP_SERVER_HOST=localhost

# Slack Configuration
# Note: Since we will be using the Slack CLI (`slack run`), the CLI actually manages 
# your tokens automatically. You don't strictly need to put them here for the Deno app.
# However, if you need them for manual testing, here is where to find them on https://api.slack.com/apps/ :
# 1. SLACK_BOT_TOKEN (starts with xoxb-): Go to "OAuth & Permissions" -> "Bot User OAuth Token"
# 2. SLACK_APP_TOKEN (starts with xapp-): Go to "Basic Information" -> "App-Level Tokens" (Create one with `connections:write` scope)
# 3. SLACK_SIGNING_SECRET: Go to "Basic Information" -> "App Credentials"
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# External API Configuration (NO API KEYS NEEDED FOR THESE!)
FEMA_API_BASE_URL=https://www.fema.gov/api/open/v2
NWS_API_BASE_URL=https://api.weather.gov
RELIEFWEB_API_BASE_URL=https://api.reliefweb.int/v1
OPENMETEO_API_BASE_URL=https://api.open-meteo.com/v1
